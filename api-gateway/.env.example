# =========================
# APPLICATION
# =========================
PORT=3000

# =========================
# POSTGRES
# =========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_database

POSTGRES_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# =========================
# MONGO
# =========================
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=your_user
MONGO_PASSWORD=your_password
MONGO_DB=your_database
MONGO_AUTH_SOURCE=admin

MONGO_URL=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_DB}?authSource=${MONGO_AUTH_SOURCE}

# =========================
# RABBITMQ
# =========================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=user
RABBITMQ_PASSWORD=password

RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}

# =========================
# JWT
# =========================
JWT_SECRET=change_this_secret
JWT_EXPIRATION=15m

